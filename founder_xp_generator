<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --cream: #EBEAE3;
  --ink: #000;
  --ink-mid: #444;
  --ink-light: #888;
  --ink-faint: #D1D1D1;
  --rule: #D1D1D1;
  --amber: #f29138;
  --amber-light: #f7e4d0;
  --blue: #4A90C4;
  --blue-light: #cee5f7;
  --coral: #711213;
  --coral-light: #FFC7C8;
  --green: #84A873;
  --green-light: #C1F4A8;
  --teal: #232262;
  --teal-light: #cbcafa;
  --purple: #7482E8;
  --purple-light: #EEEDFE;
}

body { background: var(--cream); color: var(--ink); font-family: 'DM Sans', sans-serif; font-size: 16px; line-height: 1.6; min-height: 100vh; }

/* ── NAV ── */
.top-nav { position: sticky; top: 0; z-index: 100; background: #fff; border-bottom: 1px solid var(--rule); }
.top-nav-inner { max-width: 1100px; margin: 0 auto; padding: 12px 24px; display: flex; align-items: center; justify-content: space-between; }
.brand { font-size: 11px; font-weight: 500; letter-spacing: .12em; text-transform: uppercase; color: #888; }
.nav-r a { margin-left: 20px; text-decoration: none; font-size: 11px; font-weight: 500; letter-spacing: .12em; text-transform: uppercase; color: var(--amber); border-bottom: 1px solid transparent; padding-bottom: 1px; }
.nav-r a:hover { border-bottom-color: var(--blue); }
.nav-r a.active { color: var(--ink); border-bottom-color: var(--ink); }

/* ── HEADER ── */
header { border-bottom: 1px solid var(--rule); padding: 48px 60px 36px; }
.eyebrow { font-size: 11px; font-weight: 500; letter-spacing: .12em; text-transform: uppercase; color: var(--ink-light); margin-bottom: 8px; }
.page-title { font-family: 'DM Serif Display', Georgia, serif; font-size: clamp(28px, 4vw, 42px); color: var(--ink); line-height: 1.15; margin-bottom: 8px; }
.page-sub { font-size: 14px; color: var(--ink-mid); max-width: 560px; }

/* ── LAYOUT ── */
.page-wrap { max-width: 720px; margin: 0 auto; padding: 48px 24px 80px; transition: max-width .3s ease; }
.page-wrap.wide { max-width: 980px; }
.hidden { display: none !important; }

/* ── PROGRESS ── */
.prog-track { display: flex; align-items: center; gap: 6px; margin-bottom: 44px; }
.pbar { height: 3px; flex: 1; background: var(--rule); border-radius: 3px; transition: background .3s; }
.pbar.done { background: var(--ink); }
.pbar.cur { background: #aaa; }
.plabel { font-size: 11px; font-weight: 500; letter-spacing: .08em; text-transform: uppercase; color: var(--ink-light); white-space: nowrap; padding-left: 10px; }

/* ── QUESTION SCREENS ── */
.qscreen { display: none; }
.qscreen.active { display: block; animation: slideup .25s ease both; }
@keyframes slideup { from { opacity: 0; transform: translateY(14px); } to { opacity: 1; transform: translateY(0); } }

.qnum { font-size: 11px; font-weight: 500; letter-spacing: .1em; text-transform: uppercase; color: var(--ink-light); margin-bottom: 10px; }
.qtxt { font-family: 'DM Serif Display', Georgia, serif; font-size: clamp(22px, 3vw, 30px); color: var(--ink); line-height: 1.2; margin-bottom: 28px; }

/* ── ANSWER BUTTONS ── */
.alist { display: flex; flex-direction: column; gap: 8px; margin-bottom: 28px; }
.abtn {
  display: flex; align-items: flex-start; gap: 14px;
  padding: 15px 16px; background: #fff;
  border: 1px solid var(--rule); border-radius: 12px;
  cursor: pointer; text-align: left; width: 100%;
  font-family: 'DM Sans', sans-serif;
  transition: border-color .12s, box-shadow .12s;
}
.abtn:hover { border-color: #aaa; background: #fafaf8; }
.abtn.sel { border-color: var(--ink); box-shadow: inset 0 0 0 1px var(--ink); background: #fff; }

.aem { font-size: 20px; flex-shrink: 0; line-height: 1.4; margin-top: 2px; }
.abody { flex: 1; }
.at { display: block; font-size: 14px; font-weight: 500; color: var(--ink); line-height: 1.3; }
.as { display: block; font-size: 12px; color: var(--ink-light); margin-top: 3px; line-height: 1.4; }

.radio-ring {
  width: 18px; height: 18px; border-radius: 50%;
  border: 1.5px solid var(--rule); flex-shrink: 0;
  display: flex; align-items: center; justify-content: center;
  transition: all .12s; margin-top: 3px; pointer-events: none;
}
.abtn.sel .radio-ring { background: var(--ink); border-color: var(--ink); }
.radio-dot { width: 6px; height: 6px; border-radius: 50%; background: #fff; display: none; }
.abtn.sel .radio-dot { display: block; }

/* ── Q NAVIGATION ── */
.qnav { display: flex; align-items: center; justify-content: space-between; }
.btn-back {
  padding: 9px 18px; background: none; border: 1px solid var(--rule); border-radius: 20px;
  font-size: 13px; font-family: 'DM Sans', sans-serif; color: var(--ink-light);
  cursor: pointer; transition: all .12s;
}
.btn-back:hover:not(:disabled) { border-color: #888; color: var(--ink); }
.btn-back:disabled { opacity: .3; cursor: default; pointer-events: none; }

.btn-next {
  padding: 10px 24px; background: var(--ink); color: #fff;
  border: none; border-radius: 20px; font-size: 13px; font-weight: 500;
  font-family: 'DM Sans', sans-serif; cursor: pointer; transition: background .12s;
}
.btn-next:disabled { opacity: .25; cursor: default; }
.btn-next:not(:disabled):hover { background: #222; }

.btn-generate {
  padding: 11px 26px; background: #EA3D3E; color: #fff;
  border: none; border-radius: 20px; font-size: 13px; font-weight: 500;
  font-family: 'DM Sans', sans-serif; cursor: pointer; transition: background .12s;
}
.btn-generate:disabled { opacity: .25; cursor: default; }
.btn-generate:not(:disabled):hover { background: var(--coral); }

/* ── LOADING ── */
#loading { display: none; text-align: center; padding: 72px 0; }
#loading.active { display: block; animation: slideup .2s ease both; }
.ldots { display: flex; justify-content: center; gap: 8px; margin-bottom: 16px; }
.ldot { width: 8px; height: 8px; border-radius: 50%; background: var(--rule); animation: dp 1.4s ease-in-out infinite; }
.ldot:nth-child(2) { animation-delay: .22s; }
.ldot:nth-child(3) { animation-delay: .44s; }
@keyframes dp { 0%,60%,100% { background: var(--rule); transform: scale(1); } 30% { background: var(--ink); transform: scale(1.35); } }
.ltxt { font-size: 14px; color: var(--ink-light); }

/* ── RESULTS ── */
#results { display: none; }

/* Persona card */
.pcard {
  background: #fff; border: 1px solid var(--rule); border-radius: 14px;
  padding: 28px; margin-bottom: 16px; position: relative; overflow: hidden;
}
.paccent { position: absolute; top: 0; right: 0; width: 120px; height: 120px; border-radius: 0 14px 0 100px; opacity: .12; }
.pbadge { display: inline-flex; align-items: center; gap: 6px; font-size: 11px; font-weight: 500; letter-spacing: .08em; text-transform: uppercase; padding: 4px 12px; border-radius: 20px; margin-bottom: 14px; }
.phl { font-family: 'DM Serif Display', Georgia, serif; font-size: clamp(22px, 3vw, 30px); color: var(--ink); line-height: 1.2; margin-bottom: 10px; }
.pdesc { font-size: 14px; color: var(--ink-mid); line-height: 1.65; max-width: 600px; }

/* Stack card */
.stack-card { background: #fff; border: 1px solid var(--rule); border-radius: 14px; padding: 20px 24px; margin-bottom: 16px; }
.sec-label { font-size: 10px; font-weight: 500; letter-spacing: .1em; text-transform: uppercase; color: var(--ink-faint); margin-bottom: 14px; }
.stack-row { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
.spill { padding: 8px 14px; border-radius: 8px; }
.sn { display: block; font-size: 13px; font-weight: 500; }
.sl { display: block; font-size: 10px; opacity: .65; }
.sarr { color: var(--ink-faint); font-size: 14px; flex-shrink: 0; }

/* Two-col grid */
.rgrid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px; }
.rcard { background: #fff; border: 1px solid var(--rule); border-radius: 14px; padding: 20px; }
.rc-title { font-size: 12px; font-weight: 500; color: var(--ink); padding-bottom: 12px; border-bottom: 1px solid var(--rule); margin-bottom: 16px; }

/* Steps */
.step { display: flex; gap: 12px; margin-bottom: 14px; padding-bottom: 14px; border-bottom: 1px solid var(--rule); }
.step:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
.step-n { width: 22px; height: 22px; border-radius: 50%; background: #1a1a1a; color: #fff; font-size: 10px; font-weight: 600; display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 2px; }
.step.urg .step-n { background: #EA3D3E; }
.step-a { display: block; font-size: 13px; font-weight: 500; color: var(--ink); margin-bottom: 2px; line-height: 1.3; }
.step-d { font-size: 12px; color: var(--ink-light); line-height: 1.4; }

/* Event cards */
.ev { margin-bottom: 14px; padding-bottom: 14px; border-bottom: 1px solid var(--rule); }
.ev:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
.ev-tag { display: inline-block; font-size: 10px; font-weight: 500; letter-spacing: .05em; text-transform: uppercase; padding: 2px 8px; border-radius: 10px; margin-bottom: 5px; }
.ev-name { font-size: 13px; font-weight: 500; color: var(--ink); margin-bottom: 3px; line-height: 1.3; }
.ev-meta { font-size: 11px; color: var(--ink-light); display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 4px; }
.ev-desc { font-size: 12px; color: var(--ink-mid); line-height: 1.45; margin-bottom: 6px; }
.link-btn { font-size: 11px; font-weight: 500; color: var(--ink); background: none; border: none; padding: 0; cursor: pointer; font-family: 'DM Sans', sans-serif; text-decoration: underline; text-decoration-color: var(--rule); text-underline-offset: 3px; transition: color .12s; }
.link-btn:hover { color: #EA3D3E; text-decoration-color: #EA3D3E; }

/* Office hours */
.oh-wrap { background: #fff; border: 1px solid var(--rule); border-radius: 14px; padding: 20px 24px; margin-bottom: 16px; }
.oh-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-top: 14px; }
.oh-cell { border: 1px solid var(--rule); border-radius: 10px; padding: 14px; }
.oh-tag { display: inline-block; font-size: 10px; font-weight: 500; letter-spacing: .05em; text-transform: uppercase; padding: 2px 8px; border-radius: 10px; margin-bottom: 7px; }
.oh-name { font-size: 13px; font-weight: 500; color: var(--ink); margin-bottom: 3px; line-height: 1.3; }
.oh-sched { font-size: 11px; color: var(--ink-light); margin-bottom: 6px; }
.oh-desc { font-size: 12px; color: var(--ink-mid); line-height: 1.4; margin-bottom: 8px; }

/* Results footer */
.r-footer { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; padding-top: 4px; }
.r-btn { padding: 9px 18px; border: 1px solid var(--rule); border-radius: 20px; font-size: 12px; font-family: 'DM Sans', sans-serif; cursor: pointer; color: var(--ink-mid); background: #fff; text-decoration: none; display: inline-block; transition: all .12s; }
.r-btn:hover { background: #f5f5f3; border-color: #888; color: var(--ink); }
.r-btn.acc { color: var(--amber); border-color: var(--amber-light); background: var(--amber-light); }
.r-btn.acc:hover { background: #e8c89a; }

/* Persona color stripe on top border of pcard */
.pcard { border-top-width: 3px; }

@media (max-width: 640px) {
  header { padding: 32px 20px 24px; }
  .page-wrap { padding: 32px 16px 60px; }
  .rgrid { grid-template-columns: 1fr; }
  .oh-grid { grid-template-columns: 1fr; }
  .stack-row { gap: 6px; }
}
</style>
