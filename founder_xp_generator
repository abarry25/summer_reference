function pick(btn) {
  const q = btn.dataset.q;
  document.querySelectorAll(`.abtn[data-q="${q}"]`).forEach(b => b.classList.remove('sel'));
  btn.classList.add('sel');
  A[`q${q}`] = btn.dataset.val;
  const nb = document.getElementById(`n${q}`);
  if (nb) nb.disabled = false;
}

function fwd(from, to, step) {
  document.getElementById(from).classList.remove('active');
  document.getElementById(to).classList.add('active');
  setprog(step);
}

function back(from, to, step) {
  document.getElementById(from).classList.remove('active');
  document.getElementById(to).classList.add('active');
  setprog(step);
}

